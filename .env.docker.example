# Copy to .env (same directory as docker-compose.yml) before running
# `docker compose up`. Docker Compose loads .env automatically.
#
# This is separate from .env.example (which is for running the API/worker
# directly on your machine, not via Docker) because the variable shapes
# are different -- e.g. DATABASE_URL vs POSTGRES_USER/PASSWORD/DB.

# Your real domain, e.g. stockscout.example.com -- Caddy automatically
# gets a Let's Encrypt certificate for this. Leave as localhost for a
# local docker-compose smoke test (plain HTTP, no cert).
DOMAIN=localhost

POSTGRES_USER=stockscout
POSTGRES_PASSWORD=changeme-use-a-real-password
POSTGRES_DB=stockscout

# 14 days, in seconds. How long a login session stays valid.
SESSION_TTL_SECONDS=1209600
