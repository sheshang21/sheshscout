# Copy to .env and fill in for local dev (docker-compose.dev.yml matches these defaults)

DATABASE_URL=postgresql+psycopg2://stockscout:stockscout@localhost:5432/stockscout
REDIS_URL=redis://localhost:6379/0

# CELERY_ALWAYS_EAGER=true runs scan tasks inline (no worker needed) -- only
# for tests/local debugging. Leave unset (or false) for real usage so scans
# actually go through a Celery worker: celery -A app.celery_app worker
CELERY_ALWAYS_EAGER=false

# Leave as "lax" unless frontend and API are on different origins/domains
# (e.g. deployed as separate Render services) -- see DEPLOY.md.
COOKIE_SAMESITE=lax
